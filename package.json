{
  "name": "@forge-ahead/logging",
  "version": "0.0.0",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    }
  },
  "main": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "changelog": "git cliff",
    "check": "npm run format:check && npm run lint:check && npm run typecheck && npm run test",
    "clean": "rm -rf ./node_modules && rm package-lock.json && rm -rf ./dist && rm -rf .cocoindex_code",
    "dev": "tsdown --watch",
    "format": "biome format --write",
    "format:check": "biome format",
    "lint:check": "biome lint",
    "lint:fix": "biome lint --write",
    "prepare": "npm run build",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@forge-ahead/errors": "github:ibuchanan/forge-ahead-errors",
    "pino": "^10.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@types/node": "22",
    "@vitest/coverage-v8": "^4.1.10",
    "tsdown": "^0.22",
    "typescript": "^5.9",
    "vitest": "^4.1"
  },
  "engines": {
    "node": ">=22"
  }
}
