{
  "name": "@forge-ahead/logging",
  "version": "0.2.1",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    },
    "./demo": {
      "import": "./dist/demo.mjs",
      "types": "./dist/demo.d.mts"
    }
  },
  "main": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "files": [
    "dist",
    "demo/package.json"
  ],
  "scripts": {
    "build": "tsdown",
    "changelog": "touch CHANGELOG.md && git cliff --offline --unreleased --prepend CHANGELOG.md",
    "check": "lefthook run pre-push --force",
    "clean": "rm -rf ./node_modules && rm package-lock.json && rm -rf ./dist",
    "dev": "tsdown --watch",
    "format": "biome format --write",
    "format:check": "biome format",
    "lint": "lefthook run lint",
    "lint:check": "biome lint",
    "lint:fix": "biome lint --write",
    "prepare": "npm run build && (lefthook install || true)",
    "release:prepare": "scripts/release-prepare.sh",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest watch",
    "typecheck": "tsc --noEmit"
  },
  "overrides": {
    "rolldown-plugin-dts": {
      "yuku-parser": "0.6.3"
    }
  },
  "dependencies": {
    "@forge-ahead/errors": "github:ibuchanan/forge-ahead-errors",
    "pino": "^10.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.4",
    "@types/node": "22",
    "@vitest/coverage-v8": "^4.1",
    "lefthook": "^2.1",
    "tsdown": "^0.22",
    "typescript": "^5.9",
    "vitest": "^4.1"
  },
  "engines": {
    "node": ">=22"
  }
}
